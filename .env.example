# Public site URL with https, no trailing slash. Used at build time for Open Graph /
# WhatsApp / Facebook link previews (og:image must be absolute).
# Set in Netlify (or host) → Environment variables → VITE_SITE_URL
VITE_SITE_URL=https://aurummisticaoficial.com.br

# Optional: paste the verification token from Google Search Console. If unset, the meta tag is omitted.
# VITE_GOOGLE_SITE_VERIFICATION=

# Optional: Bing Webmaster Tools msvalidate.01 content, only if you verify with an HTML meta tag.
# If the site was imported from Google Search Console and Bing shows it as already verified, leave unset.
# VITE_BING_SITE_VERIFICATION=
